---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
---

<Layout>
  <main
    class="flex h-full flex-col lg:flex-row lg:items-stretch"
    id="main-content"
    data-layout="index"
  >
    <section
      class="mx-0 h-[300px] w-full max-w-none flex-shrink-0 px-0 md:h-[500px] lg:h-auto lg:w-1/3"
      id="family-photo"
    >
    </section>
    <section
      id="hero"
      class="mx-0 flex h-auto w-full max-w-none flex-grow flex-col px-12 pt-8 pb-6 lg:w-2/3 lg:flex-grow-0 lg:overflow-y-auto"
    >
      <div class="flex flex-grow flex-col lg:justify-center">
        <h1
          class="my-4 inline-block text-center text-4xl font-bold sm:my-8 sm:text-5xl"
        >
          Thank you!
        </h1>

        <p class="my-2">
          It looks like you found my luggage! Thank you for scanning the code. Please reach out to me at dabernathy89@gmail.com or 817-891-5537 so I can arrange to retrieve it.
        </p>
      </div>
      <Footer noMarginTop />
    </section>
  </main>
</Layout>

<style>
  #family-photo {
    background-image: url("../assets/images/abernathy-family.webp");
    background-size: cover;
    background-position: center 30%;
  }

  #hero {
    background: linear-gradient(
      120deg,
      #faf8f3 0%,
      #f0ebd2 40%,
      #e8dcc0 70%,
      #ddd0b0 100%
    );
  }
</style>
